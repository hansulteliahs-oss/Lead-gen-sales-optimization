# Supabase — get from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-side only — NO NEXT_PUBLIC_ prefix — never expose to client bundle
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared secret for Make.com webhook authentication
# Generate with: openssl rand -hex 32
MAKE_WEBHOOK_SECRET=your_make_webhook_secret_here
